# Copia este archivo como ".env" y llena tus valores reales.
# Nota: el .env se declara como asset en pubspec.yaml, por lo que se empaqueta
# dentro del build de la app al compilar (ver flutter > assets en pubspec.yaml).

# ─── Correo (Gmail SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USUARIO=tudireccion@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_NOMBRE_REMITENTE=Taller Mecánico

# ─── Datos del taller (para las plantillas de correo) ───
TALLER_NOMBRE=Taller Mecánico
TALLER_TELEFONO=+504 0000-0000
TALLER_HORARIO=Lunes a viernes, 8:00 a 17:00